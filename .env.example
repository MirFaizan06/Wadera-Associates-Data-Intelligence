# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="mysql://user:pass@localhost:3306/wadera_db"

# JWT
JWT_SECRET="your-very-long-random-secret-here"
JWT_EXPIRES_IN="7d"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Email (Nodemailer)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@waderaassociates.com"

# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_BUCKET_NAME=""

# Exchange Rate API
EXCHANGE_RATE_API_KEY=""
EXCHANGE_RATE_API_URL="https://api.exchangerate-api.com/v4/latest/INR"

# Geolocation API
GEOLOCATION_API_KEY=""
GEOLOCATION_API_URL="https://api.ipgeolocation.io/ipgeo"

# Frontend URL (for CORS, email links)
FRONTEND_URL="http://localhost:3000"

# Redis (optional caching)
REDIS_URL="redis://localhost:6379"

# Developer Admin Seed
DEVELOPER_ADMIN_EMAIL="admin@waderaassociates.com"
DEVELOPER_ADMIN_PASSWORD="ChangeMe@123"

# Logging
LOG_LEVEL="info"
